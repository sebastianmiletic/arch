// providers/base.ts — Abstract base class for all AI providers.
// ---------------------------------------------------------------------------

import {
  type AIProviderConfig,
  type AIChatRequest,
  type AIChatResponse,
  type AIStreamChunk,
  type AIModel,
  type AIConnectionTest,
} from 'types.js';

export abstract class BaseAIProvider {
  config: AIProviderConfig;

  constructor(config: AIProviderConfig) {
    this.config = config;
  }

  abstract id: string;
  abstract name: string;
  abstract type: string;

  /** Returns true when the provider advertises a given capability. */
  supports(feature: string): boolean {
    return Boolean(
      this.config.capabilities?.some(
        (c) => c.toLowerCase() === feature.toLowerCase()
      )
    );
  }

  /** Quick reachability + auth + latency check. Must be overridden for deeper tests. */
  async test(): Promise<AIConnectionTest> {
    const start = Date.now();
    try {
      const models = await this.listModels();
      const latency = Date.now() - start;
      return {
        ok: true,
        latency,
        models,
        capabilities: this.getCapabilities(),
        streaming: this.supports('stream'),
      };
    } catch (err) {
      const latency = Date.now() - start;
      return {
        ok: false,
        latency,
        error: err instanceof Error ? err.message : String(err),
        capabilities: this.getCapabilities(),
        streaming: this.supports('stream'),
      };
    }
  }

  /** Synchronous chat completion. */
  abstract chat(request: AIChatRequest): Promise<AIChatResponse>;

  /** Streaming chat completion. */
  abstract stream(request: AIChatRequest): AsyncGenerator<AIStreamChunk>;

  /** List available models from the provider. */
  abstract listModels(): Promise<AIModel[]>;

  /** Embed a batch of strings. */
  abstract embed(texts: string[]): Promise<number[][]>;

  /** Build standard request headers. */
  buildHeaders(): Record<string, string> {
    const headers: Record<string, string> = {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
    };
    if (this.config.apiKey) {
      headers['Authorization'] = `Bearer ${this.config.apiKey}`;
    }
    return headers;
  }

  /** Build an OpenAI-compatible JSON request body. */
  buildBody(request: AIChatRequest): string {
    const messages = request.messages.map((m) => ({
      role: m.role,
      content: m.content,
    }));
    const payload: Record<string, unknown> = {
      model: request.model ?? this.config.defaultModel,
      messages,
      temperature: request.temperature ?? this.config.temperature,
      max_tokens: request.maxTokens ?? this.config.maxTokens,
    };
    if (request.stream) payload.stream = true;
    if (request.tools) payload.tools = request.tools;
    return JSON.stringify(payload);
  }

  /** Parse a standard OpenAI-compatible chat response JSON object. */
  parseStandardResponse(data: any): AIChatResponse {
    const choice = data?.choices?.[0];
    const content = choice?.message?.content ?? '';
    const model = data?.model ?? this.config.defaultModel;
    const usage = data?.usage;
    return {
      content,
      model,
      tokens: usage
        ? {
            prompt: usage.prompt_tokens,
            completion: usage.completion_tokens,
            total: usage.total_tokens,
          }
        : undefined,
    };
  }

  /** Parse a single SSE line from an OpenAI-compatible stream. */
  parseStandardStream(chunk: string): AIStreamChunk | null {
    const line = chunk.trim();
    if (!line || line === 'data: [DONE]') return null;
    const jsonStr = line.replace(/^data: /, '');
    try {
      const parsed = JSON.parse(jsonStr);
      const delta = parsed?.choices?.[0]?.delta;
      const content = delta?.content ?? '';
      const finishReason = parsed?.choices?.[0]?.finish_reason;
      return {
        content,
        done: finishReason != null,
        model: parsed?.model,
      };
    } catch {
      return null;
    }
  }

  /** Return the list of capabilities this provider offers. */
  abstract getCapabilities(): string[];
}
