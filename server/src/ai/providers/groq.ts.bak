// providers/groq.ts — Groq Provider Adapter (OpenAI-compatible)
// ---------------------------------------------------------------------------

import {
  type AIProviderConfig,
  type AIChatRequest,
  type AIChatResponse,
  type AIStreamChunk,
  type AIModel,
  type AIConnectionTest,
} from 'types.js';
import { OpenAIProvider } from './openai.js';

export class GroqProvider extends OpenAIProvider {
  id = 'groq';
  name = 'Groq';
  type = 'groq';

  constructor(config: AIProviderConfig) {
    super({
      ...config,
      baseUrl: (config.baseUrl ?? 'https://api.groq.com/openai/v1').replace(/\/+$/, ''),
    });
  }

  getCapabilities(): string[] {
    return this.config.capabilities?.length
      ? this.config.capabilities
      : ['chat', 'stream', 'tool_call'];
  }

  async listModels(): Promise<AIModel[]> {
    const res = await fetch(`${(this.config.baseUrl ?? 'https://api.groq.com/openai/v1').replace(/\/+$/, '')}/models`, {
      headers: this.buildHeaders(),
      signal: AbortSignal.timeout(30000),
    });
    if (!res.ok) throw new Error(`Groq list models error: ${res.status}`);
    const data = await res.json();
    const list: any[] = data?.data ?? [];
    return list.map((m: any) => ({
      id: m.id,
      name: m.id,
      provider: this.id,
      description: m.owned_by ?? undefined,
    }));
  }

  async embed(_texts: string[]): Promise<number[][]> {
    throw new Error('Groq does not currently expose an embedding endpoint.');
  }

  async test(): Promise<AIConnectionTest> {
    const start = Date.now();
    try {
      const models = await this.listModels();
      return {
        ok: true,
        latency: Date.now() - start,
        models,
        capabilities: this.getCapabilities(),
        streaming: this.supports('stream'),
      };
    } catch (err) {
      return {
        ok: false,
        latency: Date.now() - start,
        error: err instanceof Error ? err.message : String(err),
        capabilities: this.getCapabilities(),
        streaming: this.supports('stream'),
      };
    }
  }
}
